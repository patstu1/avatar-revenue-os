# ── AI Avatar Revenue OS ── Environment Configuration ──
# Copy to .env and fill in values.  Lines marked REQUIRED must be set before deploy.

# ── Project Identity ──
COMPOSE_PROJECT_NAME=avatar-revenue-os

# ── Domain (Caddy reverse proxy — auto-HTTPS via Let's Encrypt) ──
DOMAIN=app.nvironments.com                          # REQUIRED

# ── PostgreSQL ──
POSTGRES_USER=avataros                              # REQUIRED
POSTGRES_PASSWORD=changeme_in_production            # REQUIRED — generate a strong password
POSTGRES_DB=avatar_revenue_os
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://avataros:changeme_in_production@postgres:5432/avatar_revenue_os
DATABASE_URL_SYNC=postgresql://avataros:changeme_in_production@postgres:5432/avatar_revenue_os

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=changeme_generate_a_real_secret_key  # REQUIRED — 32+ random chars
API_CORS_ORIGINS=["https://app.nvironments.com"]
API_ENV=production
LOG_LEVEL=WARNING

# ── Web / Frontend ──
NEXT_PUBLIC_API_URL=https://app.nvironments.com     # REQUIRED
FRONTEND_URL=https://app.nvironments.com
WEBHOOK_BASE_URL=https://app.nvironments.com/api/v1/webhooks

# ── S3-Compatible Storage ──
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=avatar-revenue-os
S3_REGION=us-east-1

# ══════════════════════════════════════════════════════════════════════════════
#  AI PROVIDERS — Tiered Routing Stack
# ══════════════════════════════════════════════════════════════════════════════

# ── Text / LLM ──
# hero -> Claude | standard -> Gemini Flash | bulk -> DeepSeek
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=

# ── Image ──
# hero -> GPT Image 1.5 | standard/bulk -> Imagen 4 Fast (via fal)
FAL_API_KEY=
REPLICATE_API_TOKEN=
STABILITY_API_KEY=

# ── Video ──
# hero -> Runway Gen-4 | standard/bulk -> Kling AI
RUNWAY_API_KEY=
KLING_API_KEY=
HIGGSFIELD_API_KEY=

# ── Avatar ──
# primary -> HeyGen | budget fallback -> D-ID | optional -> Tavus, Synthesia
HEYGEN_API_KEY=
DID_API_KEY=
TAVUS_API_KEY=
SYNTHESIA_API_KEY=

# ── Voice ──
# hero -> ElevenLabs | standard -> Fish Audio | bulk -> Voxtral (Mistral)
ELEVENLABS_API_KEY=
FISH_AUDIO_API_KEY=

# ── Music ──
SUNO_API_KEY=
MUBERT_API_KEY=

# ══════════════════════════════════════════════════════════════════════════════
#  SOCIAL PUBLISHING
# ══════════════════════════════════════════════════════════════════════════════

# ── Distribution Aggregators (at least one required) ──
# System tries in order: Buffer -> Publer -> Ayrshare
BUFFER_API_KEY=
PUBLER_API_KEY=
AYRSHARE_API_KEY=

# ── YouTube OAuth ──
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_OAUTH_TOKEN=
YOUTUBE_REFRESH_TOKEN=

# ── TikTok OAuth ──
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# ── Instagram / Meta ──
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=

# ── X (Twitter) OAuth ──
X_CLIENT_ID=
X_CLIENT_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ── Analytics ──
SERPAPI_KEY=

