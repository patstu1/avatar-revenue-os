# ── AI Avatar Revenue OS ── Environment Configuration ──
# Copy to .env and fill in values

# ── Project Identity ──
COMPOSE_PROJECT_NAME=avatar-revenue-os

# ── Domain (Caddy reverse proxy — auto-HTTPS via Let's Encrypt) ──
DOMAIN=app.nvironments.com

# ── PostgreSQL ──
POSTGRES_USER=avataros
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=avatar_revenue_os
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://avataros:changeme_in_production@postgres:5432/avatar_revenue_os
DATABASE_URL_SYNC=postgresql://avataros:changeme_in_production@postgres:5432/avatar_revenue_os

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=changeme_generate_a_real_secret_key
API_CORS_ORIGINS=["http://localhost:3001","http://web:3000","https://app.nvironments.com"]
API_ENV=development

# ── Web ──
# Local: http://localhost:8001 | Production: https://app.nvironments.com
NEXT_PUBLIC_API_URL=https://app.nvironments.com

# ── S3-Compatible Storage ──
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=avatar-revenue-os
S3_REGION=us-east-1

# ── AI Providers — Tiered Routing Stack ──
# TEXT:  hero -> Claude,  standard -> Gemini Flash,  bulk -> DeepSeek
# IMAGE: hero -> GPT Image 1.5,  standard/bulk -> Imagen 4 Fast
# VIDEO: hero -> Runway Gen-4,  standard/bulk -> Kling AI
# AVATAR: all -> HeyGen (primary) / D-ID (budget fallback)
# VOICE: hero -> ElevenLabs,  standard -> Fish Audio,  bulk -> Voxtral
# MUSIC: all -> Suno
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
FAL_API_KEY=
RUNWAY_API_KEY=
HIGGSFIELD_API_KEY=
HEYGEN_API_KEY=
DID_API_KEY=
SYNTHESIA_API_KEY=
ELEVENLABS_API_KEY=
FISH_AUDIO_API_KEY=
MISTRAL_API_KEY=
SUNO_API_KEY=
MUBERT_API_KEY=
STABILITY_API_KEY=
TAVUS_API_KEY=

# ── Testing ──
# Pytest integration tests (create DB first: createdb … avatar_revenue_os_test).
# From host machine with Compose Postgres mapped to 5433:
# TEST_DATABASE_URL=postgresql+asyncpg://avataros:changeme_in_production@127.0.0.1:5433/avatar_revenue_os_test
# Inside Docker network (e.g. exec into api container):
TEST_DATABASE_URL=postgresql+asyncpg://avataros:changeme_in_production@postgres:5432/avatar_revenue_os_test

# ── Social Distribution Layer (multi-distributor with failover) ──
# At least one must be set. System tries in order: Buffer → Publer → Ayrshare.
BUFFER_API_KEY=
PUBLER_API_KEY=
AYRSHARE_API_KEY=

# ── Payment / E-commerce Connectors ──
# P0: Required for revenue tracking
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Plan Price IDs (create in Stripe Dashboard → Products → Pricing)
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_PRICE_PROFESSIONAL_ANNUAL=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_ANNUAL=
# Optional: Shopify e-commerce
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_WEBHOOK_SECRET=

# ── SMS (Twilio) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Ad Platform Reporting ──
META_ADS_ACCESS_TOKEN=
META_ADS_ACCOUNT_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_OAUTH_TOKEN=
TIKTOK_ADS_ACCESS_TOKEN=
TIKTOK_ADS_ADVERTISER_ID=

# ── SMTP Email ──
SMTP_FROM_EMAIL=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# ── Observability ──
SENTRY_DSN=
LOG_LEVEL=INFO

# ── Notifications (Scale Alerts + operator delivery) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SLACK_WEBHOOK_URL=
SMS_API_KEY=
OPERATOR_NOTIFY_EMAIL=
ESP_API_KEY=
CRM_API_KEY=
CRM_PROVIDER=

# ── Affiliate Network API Connectors ──
# Impact.com affiliate network
IMPACT_ACCOUNT_SID=
IMPACT_AUTH_TOKEN=
# ShareASale affiliate network
SHAREASALE_API_TOKEN=
SHAREASALE_API_SECRET=
SHAREASALE_MERCHANT_ID=
# CJ Affiliate (Commission Junction)
CJ_API_KEY=
# ClickBank (digital products — 50-75% commissions)
CLICKBANK_API_KEY=
CLICKBANK_CLERK_ID=
# Amazon Associates (retail — 1-10%)
AMAZON_ASSOCIATES_ACCESS_KEY=
AMAZON_ASSOCIATES_SECRET_KEY=
AMAZON_ASSOCIATES_TAG=
# Semrush ($200/sale, $10/trial — high-ticket SaaS)
SEMRUSH_AFFILIATE_KEY=
# ShareASale affiliate network (25,000+ merchants)
SHAREASALE_AFFILIATE_ID=
# Etsy affiliate (via Awin — handmade/vintage, 4%)
ETSY_AFFILIATE_API_KEY=
# TikTok Shop (product tagging in videos, 5-20%)
TIKTOK_SHOP_ACCESS_TOKEN=
# WPX Hosting ($100+/sale — no API key needed, just affiliate ID in link)
# YouTube Shopping uses GOOGLE_AI_API_KEY above
# Spotify + Target + Impact use IMPACT_ACCOUNT_SID above

# ── Celery (queues) ──
# Worker must consume all 15 queues in workers/celery_app.py — docker-compose worker includes:
# default,generation,publishing,analytics,qa,learning,portfolio,scale_alerts,notifications,
# growth_pack,revenue_ceiling_a,revenue_ceiling_b,revenue_ceiling_c,expansion_pack2,mxp
