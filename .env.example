# ── AI Avatar Revenue OS ── Environment Configuration ──
# Copy to .env and fill in values

# ── Project Identity ──
COMPOSE_PROJECT_NAME=avatar-revenue-os

# ── PostgreSQL ──
POSTGRES_USER=avataros
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=avatar_revenue_os
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://avataros:changeme_in_production@postgres:5432/avatar_revenue_os
DATABASE_URL_SYNC=postgresql://avataros:changeme_in_production@postgres:5432/avatar_revenue_os

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=changeme_generate_a_real_secret_key
API_CORS_ORIGINS=["http://localhost:3001","http://web:3000"]
API_ENV=development

# ── Web ──
NEXT_PUBLIC_API_URL=http://localhost:8001

# ── S3-Compatible Storage ──
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=avatar-revenue-os
S3_REGION=us-east-1

# ── AI Providers ──
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
TAVUS_API_KEY=
HEYGEN_API_KEY=

# ── Observability ──
SENTRY_DSN=
LOG_LEVEL=INFO
